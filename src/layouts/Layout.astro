---
import { ClientRouter } from "astro:transitions";
import { PUBLIC_GOOGLE_SITE_VERIFICATION } from "astro:env/client";
import { SITE } from "@/config";
import "@/styles/global.css";
import "photosuite/dist/photosuite.css";

import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import CalendarModal from "@/components/CalendarModal.astro";
import CalendarWidget from "@/components/CalendarWidget.astro";

export interface Props {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  cover?: string;
  canonicalURL?: string;
  published?: Date;
  scrollSmooth?: boolean;
}

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  cover = SITE.cover ? `/${SITE.cover}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  published,
  scrollSmooth = false,
} = Astro.props;

const showCalendar = SITE.showCalendar;

const socialImageURL = new URL(cover, Astro.url);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: `${title}`,
  image: `${socialImageURL}`,
  datePublished: `${published?.toISOString()}`,
  author: [
    {
      "@type": "Person",
      name: `${author}`,
      ...(profile && { url: profile }),
    },
  ],
};
---

<!doctype html>
<html
  dir={SITE.dir}
  lang={`${SITE.lang ?? "en"}`}
  class={`${scrollSmooth && "scroll-smooth"}`}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Article Published/Modified time -->
    {
      published && (
        <meta
          property="article:published_time"
          content={published.toISOString()}
        />
      )
    }

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- Google JSON-LD Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Enable RSS feed auto-discovery  -->
    <!-- https://docs.astro.build/en/recipes/rss/#enabling-rss-feed-auto-discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL("rss.xml", Astro.site)}
    />

    <meta name="theme-color" content="" />

    {
      PUBLIC_GOOGLE_SITE_VERIFICATION && (
        <meta
          name="google-site-verification"
          content={PUBLIC_GOOGLE_SITE_VERIFICATION}
        />
      )
    }

    <ClientRouter />

    <script is:inline src="/app-controls.js"></script>
  </head>
  <body>
    <slot />
    <Analytics />
    <SpeedInsights />
    {
      showCalendar && (
        <CalendarModal>
          <CalendarWidget compact />
        </CalendarModal>
      )
    }
    <script>
      import mermaid from "mermaid";

      const mermaidRoot = document.documentElement;
      const globalState = window as typeof window & {
        __mermaidObserverBound?: boolean;
      };
      let renderSeq = 0;

      const getMermaidTheme = () =>
        mermaidRoot.getAttribute("data-theme") === "dark" ? "dark" : "default";

      const isMermaidCodeBlock = (pre: HTMLPreElement) => {
        const code = pre.querySelector("code");
        if (!code) return false;

        const preLang = pre.getAttribute("data-language")?.toLowerCase();
        const codeLang = code.getAttribute("data-language")?.toLowerCase();
        if (preLang === "mermaid" || codeLang === "mermaid") return true;

        const classText = `${pre.className} ${code.className}`.toLowerCase();
        return /\blanguage-mermaid\b/.test(classText);
      };

      const getMermaidSource = (pre: HTMLPreElement) => {
        const code = pre.querySelector("code");
        return (code?.textContent ?? "").trim();
      };

      async function renderMermaidBlocks() {
        mermaid.initialize({
          startOnLoad: false,
          securityLevel: "loose",
          theme: getMermaidTheme(),
        });

        const preBlocks = Array.from(document.querySelectorAll("pre"));
        for (const preEl of preBlocks) {
          if (!(preEl instanceof HTMLPreElement)) continue;
          if (!isMermaidCodeBlock(preEl)) continue;
          if (preEl.dataset.mermaidProcessed === "true") continue;

          const source = getMermaidSource(preEl);
          if (!source) continue;

          const host = document.createElement("div");
          host.className = "mermaid-diagram my-6 overflow-x-auto";
          host.dataset.mermaidSource = source;

          try {
            const id = `mermaid-diagram-${renderSeq++}`;
            const { svg, bindFunctions } = await mermaid.render(id, source);
            host.innerHTML = svg;
            bindFunctions?.(host);
            preEl.insertAdjacentElement("afterend", host);
            preEl.dataset.mermaidProcessed = "true";
            preEl.classList.add("hidden");
          } catch (error) {
            console.error("Failed to render mermaid diagram:", error);
          }
        }
      }

      async function rerenderMermaidByTheme() {
        const hosts = Array.from(
          document.querySelectorAll(".mermaid-diagram[data-mermaid-source]")
        );
        if (hosts.length === 0) return;

        mermaid.initialize({
          startOnLoad: false,
          securityLevel: "loose",
          theme: getMermaidTheme(),
        });

        for (const hostEl of hosts) {
          if (!(hostEl instanceof HTMLElement)) continue;
          const source = hostEl.dataset.mermaidSource?.trim();
          if (!source) continue;
          try {
            const id = `mermaid-diagram-${renderSeq++}`;
            const { svg, bindFunctions } = await mermaid.render(id, source);
            hostEl.innerHTML = svg;
            bindFunctions?.(hostEl);
          } catch (error) {
            console.error("Failed to re-render mermaid diagram:", error);
          }
        }
      }

      const initMermaid = () => {
        renderMermaidBlocks();
      };

      document.addEventListener("astro:page-load", initMermaid);
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initMermaid, {
          once: true,
        });
      } else {
        initMermaid();
      }

      if (!globalState.__mermaidObserverBound) {
        const themeObserver = new MutationObserver(() => {
          rerenderMermaidByTheme();
        });
        themeObserver.observe(mermaidRoot, {
          attributes: true,
          attributeFilter: ["data-theme"],
        });
        globalState.__mermaidObserverBound = true;
      }
    </script>
  </body>
</html>
