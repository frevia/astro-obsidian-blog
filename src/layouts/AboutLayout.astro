---
/**
 * 关于页布局
 *
 * @fileoverview 关于页的特殊布局，包含博客统计动画
 *
 * 核心逻辑：
 * 1. 获取博客统计数据（运行天数、文章数、字数）
 * 2. 通过 data 属性传递统计值给客户端脚本
 * 3. 客户端实现数字增长动画
 * 4. 支持渲染时间轴（从 JSON 数据）
 *
 * 动画规格：
 * - 起始日期：1000ms
 * - 起始月份：800ms
 * - 起始日期：600ms
 * - 运行天数：2000ms
 * - 文章总数：1500ms
 * - 总字数：2500ms
 *
 * 依赖关系：
 * - 被 /about.astro 页面使用
 * - 继承 Layout.astro
 * - 导入 Header、Footer 组件
 * - 使用 getBlogMetrics 获取统计数据
 */

import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Twikoo from "@/components/Twikoo.astro";
// import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";
import { getYMDParts } from "@/utils/calendarDate";
import { getBlogMetrics } from "@/utils/getBlogMetrics";
import {
  PUBLIC_TWIKOO_ENABLED,
  PUBLIC_TWIKOO_ENV_ID,
  PUBLIC_TWIKOO_REGION,
} from "astro:env/client";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
// 获取博客统计数据
const blogStats = await getBlogMetrics();
const commentsEnabled = SITE.comments.enabled && PUBLIC_TWIKOO_ENABLED !== "false";
const hasTwikooEnv =
  (PUBLIC_TWIKOO_ENV_ID ?? "").trim().length > 0 &&
  (PUBLIC_TWIKOO_REGION ?? "").trim().length > 0;

// 解析博客创建日期
const { year: startYear, month: startMonth, day: startDay } = getYMDParts(
  SITE.createdAt
);
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <Header />
  <!-- <Breadcrumb /> -->
  <main id="main-content">
    <section id="about" class="app-prose mb-28 max-w-app prose-img:border-0">
      <!-- 统计数据容器（隐藏） -->
      <!-- 通过 data 属性传递值给客户端脚本 -->
      <div
        id="blog-stats-data"
        data-running-days={blogStats.runningDays}
        data-total-posts={blogStats.totalPosts}
        data-blog-posts={blogStats.blogPosts}
        data-diary-posts={blogStats.diaryPosts}
        data-total-words={blogStats.totalWordsInWan}
        data-start-year={startYear}
        data-start-month={startMonth}
        data-start-day={startDay}
        style="display: none;"
      >
      </div>
      <!-- 插槽：页面内容 -->
      <slot />

      {
        commentsEnabled && (
          <>
            <hr class="my-8 border-dashed" />
            <h2 class="mb-4 text-xl font-semibold">留言</h2>
          </>
        )
      }

      {commentsEnabled && hasTwikooEnv && <Twikoo />}

      {
        commentsEnabled && !hasTwikooEnv && (
          <div class="mt-8 rounded-xl border border-border/60 bg-muted/15 px-4 py-3 text-sm text-foreground/80">
            留言功能已开启，但尚未完成 Twikoo 配置。请在环境变量中设置
            <code class="mx-1 rounded bg-muted/30 px-1.5 py-0.5 text-xs">
              PUBLIC_TWIKOO_ENV_ID
            </code>
            与
            <code class="mx-1 rounded bg-muted/30 px-1.5 py-0.5 text-xs">
              PUBLIC_TWIKOO_REGION
            </code>
            后重新部署。
          </div>
        )
      }
    </section>
  </main>
  <Footer />
</Layout>

<script>
  /**
   * 数字增长动画
   *
   * @param element - 目标元素
   * @param targetValue - 目标值
   * @param duration - 动画持续时间（ms）
   * @param isDecimal - 是否为小数
   */
  function animateNumber(
    element: HTMLElement,
    targetValue: number,
    duration: number = 2000,
    isDecimal: boolean = false
  ) {
    const startValue = 0;
    const startTime = performance.now();

    function updateNumber(currentTime: number) {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);

      // 使用 easeOutQuart 缓动函数
      const easeOutQuart = 1 - Math.pow(1 - progress, 4);
      const currentValue =
        startValue + (targetValue - startValue) * easeOutQuart;

      if (isDecimal) {
        element.textContent = currentValue.toFixed(1);
      } else {
        element.textContent = Math.floor(currentValue).toString();
      }

      if (progress < 1) {
        requestAnimationFrame(updateNumber);
      } else {
        // 动画结束，设置最终值
        if (isDecimal) {
          element.textContent = targetValue.toFixed(1);
        } else {
          element.textContent = targetValue.toString();
        }
      }
    }

    requestAnimationFrame(updateNumber);
  }

  /**
   * 启动所有数字动画
   */
  function startAnimations() {
    const statsData = document.getElementById("blog-stats-data");
    if (!statsData) return;

    // 读取 data 属性中的统计值
    const runningDays = parseInt(statsData.dataset.runningDays || "0");
    const totalPosts = parseInt(statsData.dataset.totalPosts || "0");
    const blogPosts = parseInt(statsData.dataset.blogPosts || "0");
    const diaryPosts = parseInt(statsData.dataset.diaryPosts || "0");
    const totalWords = parseFloat(statsData.dataset.totalWords || "0");
    const startYear = parseInt(statsData.dataset.startYear || "2025");
    const startMonth = parseInt(statsData.dataset.startMonth || "3");
    const startDay = parseInt(statsData.dataset.startDay || "17");

    // 动画配置：每个元素的持续时间和是否为小数
    const elements = [
      { id: "start-year", value: startYear, duration: 1000 },
      { id: "start-month", value: startMonth, duration: 800 },
      { id: "start-day", value: startDay, duration: 600 },
      { id: "running-days", value: runningDays, duration: 2000 },
      { id: "total-posts", value: totalPosts, duration: 1500 },
      { id: "blog-posts", value: blogPosts, duration: 1800 },
      { id: "diary-posts", value: diaryPosts, duration: 2200 },
      { id: "total-words", value: totalWords, duration: 2500, isDecimal: true },
    ];

    // 预占位：根据最终字符串长度设置最小宽度，避免初始 0 导致布局抖动
    const setMinWidth = (el: HTMLElement, len: number) => {
      el.style.display = "inline-block";
      el.style.minWidth = `${len}ch`;
      el.style.textAlign = "center";
    };

    const elYear = document.getElementById("start-year");
    const elMonth = document.getElementById("start-month");
    const elDay = document.getElementById("start-day");
    const elDays = document.getElementById("running-days");
    const elPosts = document.getElementById("total-posts");
    const elBlogPosts = document.getElementById("blog-posts");
    const elDiaryPosts = document.getElementById("diary-posts");
    const elWords = document.getElementById("total-words");

    if (elYear) setMinWidth(elYear, String(startYear).length);
    if (elMonth) setMinWidth(elMonth, String(startMonth).length);
    if (elDay) setMinWidth(elDay, String(startDay).length);
    if (elDays) setMinWidth(elDays, String(runningDays).length);
    if (elPosts) setMinWidth(elPosts, String(totalPosts).length);
    if (elBlogPosts) setMinWidth(elBlogPosts, String(blogPosts).length);
    if (elDiaryPosts) setMinWidth(elDiaryPosts, String(diaryPosts).length);
    if (elWords) setMinWidth(elWords, totalWords.toFixed(1).length);

    // 启动数字动画（每个延迟 200ms）
    elements.forEach((item, index) => {
      const element = document.getElementById(item.id);
      if (element) {
        setTimeout(() => {
          animateNumber(
            element,
            item.value,
            item.duration,
            item.isDecimal || false
          );
        }, index * 200);
      }
    });
  }

  /**
   * 渲染博客进程时间轴
   *
   * 从 #blog-timeline-data 读取 JSON 数据
   * 生成时间轴列表项
   */
  function renderTimeline() {
    const timeline = document.getElementById("blog-timeline");
    const dataEl = document.getElementById("blog-timeline-data");

    if (!timeline || !dataEl) return;
    if (timeline.dataset.initialized === "true") return;

    try {
      const events = JSON.parse(dataEl.textContent || "[]");
      const frag = document.createDocumentFragment();

      events.forEach((evt: { date?: string; text: string }) => {
        const li = document.createElement("li");
        li.className = "flex items-center gap-2 leading-6";

        // 解析日期（格式：YYYY-MM-DD 或自定义）
        const parts = (evt.date || "").split("-");
        const ymd =
          parts.length === 3
            ? `${parts[0]}-${parts[1]}-${parts[2]}`
            : evt.date || "";

        const date = document.createElement("span");
        date.className = "text-right tabular-nums text-sm opacity-80";
        date.textContent = ymd;

        const sep = document.createElement("span");
        sep.className = "opacity-80";
        sep.textContent = "»";

        const text = document.createElement("span");
        text.className = "flex-1 text-sm text-accent truncate";
        text.textContent = evt.text;

        li.append(date, sep, text);
        frag.appendChild(li);
      });

      timeline.appendChild(frag);
      timeline.dataset.initialized = "true";
    } catch {
      /* 忽略渲染错误 */
    }
  }

  /**
   * 初始化所有动画
   */
  function initializeAnimations() {
    setTimeout(() => {
      startAnimations();
      renderTimeline();
    }, 300);
  }

  // View Transitions 导航后初始化
  document.addEventListener("astro:page-load", () => {
    initializeAnimations();
  });

  // 初始加载时初始化
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeAnimations);
  } else {
    initializeAnimations();
  }
</script>
