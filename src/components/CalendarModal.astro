---
/**
 * 日历模态框组件：点击顶部菜单的日历时显示悬浮日历，提供放大和关闭按钮
 */
---

<div
  id="calendar-modal"
  class="fixed top-20 right-4 z-50 flex hidden max-h-[min(90vh,calc(100vh-4.5rem))] w-[320px] max-w-[90vw] flex-col overflow-hidden rounded-lg border bg-white shadow-2xl dark:bg-slate-900"
>
  <!-- 头部：标题和按钮 -->
  <div class="border-skin-muted/15 shrink-0 border-b px-4 pt-4 pb-3">
    <div class="flex items-center justify-between">
      <h3 class="text-lg font-semibold">日历</h3>
      <div class="flex items-center gap-2">
        <!-- 关闭按钮 -->
        <button
          id="close-calendar-modal"
          class="text-skin-muted hover:bg-skin-muted/20 hover:text-skin-base rounded p-1.5 transition-colors"
          aria-label="关闭日历"
          title="关闭"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- 日历内容（可滚动，避免当日内容过多被裁切） -->
  <div
    class="calendar-modal-body min-h-0 flex-1 overflow-x-hidden overflow-y-auto overscroll-contain px-4 pt-2 pb-4"
  >
    <slot />
  </div>
</div>

<script>
  // 显示日历模态框
  function showCalendarModal() {
    const modal = document.getElementById("calendar-modal");
    if (modal) {
      modal.classList.remove("hidden");
    }
  }

  // 隐藏日历模态框
  function hideCalendarModal() {
    const modal = document.getElementById("calendar-modal");
    if (modal) {
      modal.classList.add("hidden");
    }
  }

  // 添加事件监听器的函数
  function addEventListeners() {
    const calendarLinks = document.querySelectorAll('a[href="/calendar"]');
    calendarLinks.forEach(link => {
      // 只对顶部导航的日历按钮添加点击事件，排除模态框中的放大按钮
      if (!link.closest("#calendar-modal")) {
        // 先移除可能存在的事件监听器，避免重复添加
        link.removeEventListener("click", handleCalendarClick);
        link.addEventListener("click", handleCalendarClick);
      }
    });

    // 为关闭按钮添加点击事件
    const closeButton = document.getElementById("close-calendar-modal");
    if (closeButton) {
      closeButton.removeEventListener("click", hideCalendarModal);
      closeButton.addEventListener("click", hideCalendarModal);
    }

    // 点击模态框外部关闭
    const modal = document.getElementById("calendar-modal");
    if (modal) {
      modal.removeEventListener("click", handleModalClick);
      modal.addEventListener("click", handleModalClick);
    }

    // 按 ESC 键关闭
    document.removeEventListener("keydown", handleEscKey);
    document.addEventListener("keydown", handleEscKey);
  }

  // 处理日历按钮点击
  function handleCalendarClick(e: Event) {
    // 阻止默认跳转
    e.preventDefault();
    // 显示模态框
    showCalendarModal();
  }

  // 处理模态框点击
  function handleModalClick() {
    // 由于移除了背景遮罩，不再需要点击外部关闭的逻辑
  }

  // 处理 ESC 键
  function handleEscKey(e: KeyboardEvent) {
    if (e.key === "Escape") {
      hideCalendarModal();
    }
  }

  // 在 DOMContentLoaded 和 pageshow 事件中添加事件监听器
  document.addEventListener("DOMContentLoaded", addEventListeners);
  window.addEventListener("pageshow", addEventListeners);

  // 视图切换后 DOM 被替换，需要重新给新的日历链接绑定“打开弹窗”逻辑
  document.addEventListener("astro:after-swap", addEventListeners);
</script>
