---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import IconCalendar from "@/assets/icons/IconCalendar.svg";
import { SITE_TIMEZONE } from "@/utils/calendarDate";
import "dayjs/locale/zh-cn";

dayjs.extend(utc);
dayjs.extend(timezone);

export interface Props {
  class?: string;
  size?: "sm" | "lg";
  timezone: string | undefined;
  published: string | Date;
  updated: string | Date | undefined | null;
}

const {
  published,
  updated,
  size = "sm",
  class: className = "",
  timezone: postTimezone,
} = Astro.props;

const isModified = updated && updated > published;
const displaySource = isModified ? updated : published;

const hasExplicitTime = (value: string | Date | undefined | null) => {
  if (!value) return false;
  if (typeof value === "string") {
    return /[T\s]\d{2}:\d{2}/.test(value.trim());
  }
  if (value instanceof Date) {
    return !(
      value.getUTCHours() === 0 &&
      value.getUTCMinutes() === 0 &&
      value.getUTCSeconds() === 0 &&
      value.getUTCMilliseconds() === 0
    );
  }
  return false;
};

const datetime = dayjs(displaySource).tz(
  postTimezone || SITE_TIMEZONE
);

const date = datetime
  .locale("zh-cn")
  .format(
    hasExplicitTime(displaySource) ? "ddd / YYYY-MM-DD HH:mm" : "ddd / YYYY-MM-DD"
  );
---

<div class:list={["flex items-center gap-x-2 opacity-80", className]}>
  <IconCalendar
    class:list={[
      "inline-block size-6 min-w-[1.375rem]",
      { "scale-90": size === "sm" },
    ]}
  />
  {
    isModified && (
      <span class:list={["text-sm", { "sm:text-base": size === "lg" }]}>
        Updated:
      </span>
    )
  }
  <time
    class:list={["text-sm", { "sm:text-base": size === "lg" }]}
    datetime={datetime.toISOString()}>{date}</time
  >
</div>
