---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import IconCalendar from "@/assets/icons/IconCalendar.svg";
import IconFavorite from "@/assets/icons/IconFavorite.svg";
import { SITE_TIMEZONE } from "@/utils/calendarDate";
import "dayjs/locale/zh-cn";

dayjs.extend(utc);
dayjs.extend(timezone);

export interface Props {
  class?: string;
  size?: "sm" | "lg";
  timezone: string | undefined;
  published: Date;
  created?: Date;
  showCreated?: boolean;
  detailPage?: boolean;
}

const {
  published,
  created,
  size = "sm",
  class: className = "",
  timezone: postTimezone,
  showCreated = false,
  detailPage = false,
} = Astro.props;

const hasExplicitTime = (value: string | Date | undefined | null) => {
  if (!value) return false;
  if (typeof value === "string") {
    return /[T\s]\d{2}:\d{2}/.test(value.trim());
  }
  if (value instanceof Date) {
    return !(
      value.getUTCHours() === 0 &&
      value.getUTCMinutes() === 0 &&
      value.getUTCSeconds() === 0 &&
      value.getUTCMilliseconds() === 0
    );
  }
  return false;
};

const formatDate = (date: string | Date, timezone: string | undefined) => {
  const datetime = dayjs(date).tz(timezone || SITE_TIMEZONE);
  return datetime
    .locale("zh-cn")
    .format(
      hasExplicitTime(date) ? "ddd / YYYY-MM-DD HH:mm" : "ddd / YYYY-MM-DD"
    );
};

const publishedDate = formatDate(published, postTimezone);
const createdDate = created ? formatDate(created, postTimezone) : null;

// 智能判断是否显示收录时间
const shouldShowCreated =
  showCreated &&
  createdDate &&
  created &&
  Math.abs(new Date(published).getTime() - new Date(created).getTime()) >
    7 * 24 * 60 * 60 * 1000;
---

<div class:list={["flex items-center gap-x-2 opacity-80", className]}>
  <IconCalendar
    class:list={[
      "inline-block size-6 min-w-[1.375rem]",
      { "scale-90": size === "sm" },
    ]}
  />
  <time
    class:list={["text-sm", { "sm:text-base": size === "lg" }]}
    datetime={dayjs(published).toISOString()}
    title="原创发布时间"
  >
    {publishedDate}
  </time>

  {
    shouldShowCreated && (
      <>
        <span class="text-foreground/40">|</span>
        <IconFavorite
          class:list={[
            "inline-block size-6 min-w-[1.375rem] text-foreground",
            { "scale-90": size === "sm" },
          ]}
        />
        <time
          class:list={[
            "text-sm",
            { "sm:text-base": size === "lg" },
            {
              "text-foreground/60": !detailPage,
              "text-foreground": detailPage,
            },
          ]}
          datetime={dayjs(created).toISOString()}
          title="收录时间"
        >
          {createdDate}
        </time>
      </>
    )
  }
</div>
