---
import chineseDays from "chinese-days";

// 获取当前日期
const now = new Date();
const year = now.getFullYear();
const month = now.getMonth() + 1;
const day = now.getDate();
const weekday = now.getDay();

// 星期几的中文表示
const weekdays = ["周日", "周一", "周二", "周三", "周四", "周五", "周六"];
const weekdayText = weekdays[weekday];

// 格式化日期为 YYYY-MM-DD
const dateKey = `${year}-${String(month).padStart(2, "0")}-${String(day).padStart(2, "0")}`;

// 获取农历信息
let lunarMonth = "";
let lunarDay = "";
try {
  const lunarInfo = chineseDays.getLunarDatesInRange(dateKey, dateKey);
  if (lunarInfo && lunarInfo.length > 0) {
    const info = lunarInfo[0];
    lunarMonth = info.lunarMonCN;
    lunarDay = info.lunarDayCN;
  }
} catch {
  // 忽略错误
}

// 获取节气信息（仅当日有节气时显示）
let solarTerm = "";
try {
  const solarTerms = chineseDays.getSolarTermsInRange(dateKey, dateKey) as Array<{
    date: string;
    name: string;
    index?: number;
  }>;
  const todaySolarTerm = solarTerms.find(
    item => item.date === dateKey && item.index === 1
  );
  if (todaySolarTerm?.name) {
    solarTerm = todaySolarTerm.name;
  }
} catch {
  // 忽略错误
}

// 判断是否为工作日
const isWorkday = weekday >= 1 && weekday <= 5;
const workdayText = isWorkday ? "工作日" : "休息啦";
const workdayClass = isWorkday
  ? "text-green-600 dark:text-green-400"
  : "text-red-600 dark:text-red-400";
---

<!-- 整颗风铃：顶环 → 绳 → 主牌 → 绳 → 坠 -->
<div class="date-chime-root inline-flex flex-col items-center">
  <div class="chime-sway-primary flex flex-col items-center">
    <span
      class="chime-ring border-accent/55 bg-background shadow-sm"
      aria-hidden="true"></span>
    <div class="chime-rope chime-rope--top"></div>

    <div
      class="hover:bg-skin-muted/20 flex cursor-pointer flex-col items-center justify-center rounded-lg border bg-background p-3 shadow-sm transition-colors"
      id="date-display-btn"
    >
      <div class="flex flex-col items-center justify-center">
        <div class="flex items-center gap-1 text-sm">
          <span class="font-medium text-red-600 dark:text-red-400"
            >{weekdayText}</span
          >
          <span class="text-skin-muted">{month}月</span>
        </div>
        <div class="text-2xl font-bold">{day}</div>
        {
          lunarMonth && lunarDay && (
            <div class="text-skin-muted text-xs">
              {lunarMonth}
              {lunarDay}
            </div>
          )
        }
      </div>
    </div>

    <div class="chime-sway-secondary flex flex-col items-center">
      {
        solarTerm ? (
          <div class="chime-solar-chain flex flex-col items-center">
            <!-- 上绳 + 五边形 + 下绳：同一 SVG、同一坐标系，与顶点/底边中点严格对齐 -->
            <div class="chime-solar-chain-inner relative w-[3.6rem] shrink-0">
              <svg
                class="chime-solar-chain-svg block overflow-visible"
                viewBox="0 0 36 69"
                width="3.6rem"
                height="6.9rem"
                aria-hidden="true"
              >
                <!-- 绳段高度 17.5 + 五边形高度 34 + 绳段 17.5 = 69（与原先 1.75rem+3.4rem+1.75rem 同比例） -->
                <line
                  class="chime-chain-stroke"
                  x1="18"
                  y1="0"
                  x2="18"
                  y2="17.5"
                  stroke-linecap="butt"></line>
                <polygon
                  class="chime-chain-stroke chime-chain-pent"
                  points="18,17.5 36,30.42 29.52,51.5 6.48,51.5 0,30.42"></polygon>
                <line
                  class="chime-chain-stroke"
                  x1="18"
                  y1="51.5"
                  x2="18"
                  y2="69"
                  stroke-linecap="butt"></line>
              </svg>
              <span
                class="text-xs font-medium text-amber-700 dark:text-amber-300 pointer-events-none absolute top-1/2 left-1/2 z-[1] max-w-[2.4rem] -translate-x-1/2 -translate-y-1/2 text-center leading-none"
              >
                {solarTerm}
              </span>
            </div>
          </div>
        ) : (
          <div class="chime-rope chime-rope--mid"></div>
        )
      }
      <div
        class="chime-workday-pill min-w-[4.5rem] rounded-full border bg-background px-2 py-1 text-center shadow-sm"
      >
        <span class={`text-xs font-medium ${workdayClass}`}>{workdayText}</span>
      </div>
    </div>
  </div>
</div>

<style>
  .chime-ring {
    display: block;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 9999px;
    border-width: 2px;
    transform-origin: top center;
  }

  .chime-rope {
    width: 2px;
    margin-left: auto;
    margin-right: auto;
    border-radius: 1px;
    background: color-mix(in oklab, var(--color-accent, #888) 32%, transparent);
  }

  .chime-rope--top {
    height: 0.65rem;
  }

  .chime-rope--mid {
    height: 1.75rem;
  }

  /* 节气链底与工作日坠略贴紧（下绳已在 SVG 内，此处只收外层缝） */
  .chime-solar-chain + .chime-workday-pill {
    margin-top: -0.06rem;
  }

  /* 无节气时：主绳与工作日坠之间略收紧 */
  .chime-sway-secondary > .chime-rope--mid + .chime-workday-pill {
    margin-top: -0.08rem;
  }

  .chime-solar-chain-svg .chime-chain-stroke {
    fill: none;
    stroke: color-mix(in oklab, var(--color-accent, #888) 32%, transparent);
    stroke-width: 2;
    vector-effect: non-scaling-stroke;
  }

  .chime-solar-chain-svg .chime-chain-pent {
    stroke-linejoin: miter;
  }

  /* 整颗挂件绕顶环摆动 */
  @keyframes chime-primary {
    0%,
    100% {
      transform: rotate(-1.4deg);
    }
    19% {
      transform: rotate(2.6deg);
    }
    41% {
      transform: rotate(-2.1deg);
    }
    63% {
      transform: rotate(1.7deg);
    }
    82% {
      transform: rotate(-1deg);
    }
  }

  /* 下摆相对主牌额外晃动，像多节风铃 */
  @keyframes chime-secondary {
    0%,
    100% {
      transform: rotate(-2deg);
    }
    14% {
      transform: rotate(4.2deg);
    }
    31% {
      transform: rotate(-3.6deg);
    }
    49% {
      transform: rotate(3deg);
    }
    66% {
      transform: rotate(-2.8deg);
    }
    84% {
      transform: rotate(1.5deg);
    }
  }

  .chime-sway-primary {
    transform-origin: top center;
    animation: chime-primary 5.5s cubic-bezier(0.4, 0.06, 0.6, 0.94) infinite;
    animation-delay: -0.9s;
  }

  .chime-sway-secondary {
    transform-origin: top center;
    animation: chime-secondary 7.1s cubic-bezier(0.36, 0.1, 0.64, 0.9) infinite;
    animation-delay: -3.2s;
  }

  @media (prefers-reduced-motion: reduce) {
    .chime-sway-primary,
    .chime-sway-secondary {
      animation: none;
    }
  }
</style>

<script>
  // 添加日期显示挂件的点击事件监听器
  function addDateDisplayListener() {
    const dateDisplayBtn = document.getElementById("date-display-btn");
    if (dateDisplayBtn) {
      // 先移除可能存在的事件监听器，避免重复添加
      dateDisplayBtn.removeEventListener("click", handleDateDisplayClick);
      dateDisplayBtn.addEventListener("click", handleDateDisplayClick);
    }
  }

  // 处理日期显示挂件点击
  function handleDateDisplayClick() {
    const calendarModal = document.getElementById("calendar-modal");
    if (calendarModal) {
      calendarModal.classList.remove("hidden");
    }
  }

  // 在 DOMContentLoaded、pageshow 和 astro:after-swap 事件中添加事件监听器
  document.addEventListener("DOMContentLoaded", addDateDisplayListener);
  window.addEventListener("pageshow", addDateDisplayListener);
  document.addEventListener("astro:after-swap", addDateDisplayListener);
</script>
