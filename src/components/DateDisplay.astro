<!-- 整颗风铃：顶环 → 绳 → 主牌 → 绳 → 坠 -->
<div
  class="date-chime-root inline-flex flex-col items-center"
  data-date-display
>
  <div class="chime-sway-primary flex flex-col items-center">
    <span
      class="chime-ring border-accent/55 bg-background shadow-sm"
      aria-hidden="true"></span>
    <div class="chime-rope chime-rope--top"></div>

    <div
      class="hover:bg-skin-muted/20 flex cursor-pointer flex-col items-center justify-center rounded-lg border bg-background p-3 shadow-sm transition-colors"
      data-date-display-btn
    >
      <div class="flex flex-col items-center justify-center">
        <div class="flex items-center gap-1 text-sm">
          <span
            class="font-medium text-red-600 dark:text-red-400"
            data-date-display-weekday></span>
          <span class="text-skin-muted"
            ><span data-date-display-month></span>月</span
          >
        </div>
        <div class="text-2xl font-bold" data-date-display-day></div>
        <div class="text-skin-muted hidden text-xs" data-date-display-lunar>
        </div>
      </div>
    </div>

    <div class="chime-sway-secondary flex flex-col items-center">
      <div class="chime-solar-chain hidden" data-date-display-solar-chain>
        <div class="chime-solar-chain-inner relative w-[3.6rem] shrink-0">
          <svg
            class="chime-solar-chain-svg block overflow-visible"
            viewBox="0 0 36 69"
            width="3.6rem"
            height="6.9rem"
            aria-hidden="true"
          >
            <line
              class="chime-chain-stroke"
              x1="18"
              y1="0"
              x2="18"
              y2="17.5"
              stroke-linecap="butt"></line>
            <polygon
              class="chime-chain-stroke chime-chain-pent"
              points="18,17.5 36,30.42 29.52,51.5 6.48,51.5 0,30.42"></polygon>
            <line
              class="chime-chain-stroke"
              x1="18"
              y1="51.5"
              x2="18"
              y2="69"
              stroke-linecap="butt"></line>
          </svg>
          <span
            class="pointer-events-none absolute top-1/2 left-1/2 z-[1] max-w-[2.4rem] -translate-x-1/2 -translate-y-1/2 text-center text-xs leading-none font-medium text-amber-700 dark:text-amber-300"
            data-date-display-solar-term></span>
        </div>
      </div>
      <div class="chime-rope chime-rope--mid" data-date-display-mid-rope></div>
      <div
        class="chime-workday-pill chime-workday-pill--with-rope min-w-[4.5rem] rounded-full border bg-background px-2 py-1 text-center shadow-sm"
        data-date-display-workday-pill
      >
        <span class="text-xs font-medium" data-date-display-workday></span>
      </div>
    </div>
  </div>
</div>

<style>
  .chime-ring {
    display: block;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 9999px;
    border-width: 2px;
    transform-origin: top center;
  }

  .chime-rope {
    width: 2px;
    margin-left: auto;
    margin-right: auto;
    border-radius: 1px;
    background: color-mix(in oklab, var(--color-accent, #888) 32%, transparent);
  }

  .chime-rope--top {
    height: 0.65rem;
  }

  .chime-rope--mid {
    height: 1.75rem;
  }

  /* 节气链底与工作日坠略贴紧（下绳已在 SVG 内，此处只收外层缝） */
  .chime-workday-pill--with-solar {
    margin-top: -0.06rem;
  }

  /* 无节气时：主绳与工作日坠之间略收紧 */
  .chime-workday-pill--with-rope {
    margin-top: -0.08rem;
  }

  .chime-solar-chain-svg .chime-chain-stroke {
    fill: none;
    stroke: color-mix(in oklab, var(--color-accent, #888) 32%, transparent);
    stroke-width: 2;
    vector-effect: non-scaling-stroke;
  }

  .chime-solar-chain-svg .chime-chain-pent {
    stroke-linejoin: miter;
  }

  .chime-solar-chain:not(.hidden) {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* 整颗挂件绕顶环摆动 */
  @keyframes chime-primary {
    0%,
    100% {
      transform: rotate(-1.4deg);
    }
    19% {
      transform: rotate(2.6deg);
    }
    41% {
      transform: rotate(-2.1deg);
    }
    63% {
      transform: rotate(1.7deg);
    }
    82% {
      transform: rotate(-1deg);
    }
  }

  /* 下摆相对主牌额外晃动，像多节风铃 */
  @keyframes chime-secondary {
    0%,
    100% {
      transform: rotate(-2deg);
    }
    14% {
      transform: rotate(4.2deg);
    }
    31% {
      transform: rotate(-3.6deg);
    }
    49% {
      transform: rotate(3deg);
    }
    66% {
      transform: rotate(-2.8deg);
    }
    84% {
      transform: rotate(1.5deg);
    }
  }

  .chime-sway-primary {
    transform-origin: top center;
    animation: chime-primary 5.5s cubic-bezier(0.4, 0.06, 0.6, 0.94) infinite;
    animation-delay: -0.9s;
  }

  .chime-sway-secondary {
    transform-origin: top center;
    animation: chime-secondary 7.1s cubic-bezier(0.36, 0.1, 0.64, 0.9) infinite;
    animation-delay: -3.2s;
  }

  @media (prefers-reduced-motion: reduce) {
    .chime-sway-primary,
    .chime-sway-secondary {
      animation: none;
    }
  }
</style>

<script>
  import chineseDays from "chinese-days";
  import { formatSiteDate, toSiteYMD } from "@/utils/calendarDate";

  const globalWindow = window as Window & {
    __dateDisplayBound?: boolean;
    __dateDisplayIntervalId?: number;
  };

  function getDisplayData() {
    const now = new Date();
    const dateKey = toSiteYMD(now);
    const [, ms, ds] = dateKey.split("-");
    const month = Number(ms);
    const day = Number(ds);
    const weekdayText = formatSiteDate(now, "zh-CN", { weekday: "short" });
    const weekdayEn = formatSiteDate(now, "en-US", { weekday: "short" });
    const isWorkday = weekdayEn !== "Sat" && weekdayEn !== "Sun";

    let lunarText = "";
    try {
      const lunarInfo = chineseDays.getLunarDatesInRange(dateKey, dateKey);
      const info = lunarInfo?.[0];
      if (info) {
        lunarText = `${info.lunarMonCN}${info.lunarDayCN}`;
      }
    } catch {}

    let solarTerm = "";
    try {
      const solarTerms = chineseDays.getSolarTermsInRange(
        dateKey,
        dateKey
      ) as Array<{
        date: string;
        name: string;
        index?: number;
      }>;
      const todaySolarTerm = solarTerms.find(
        item => item.date === dateKey && item.index === 1
      );
      solarTerm = todaySolarTerm?.name ?? "";
    } catch {}

    return {
      month,
      day,
      weekdayText,
      lunarText,
      solarTerm,
      workdayText: isWorkday ? "工作日" : "休息啦",
      isWorkday,
    };
  }

  function getElements(root: HTMLElement) {
    const button = root.querySelector("[data-date-display-btn]");
    const weekday = root.querySelector("[data-date-display-weekday]");
    const month = root.querySelector("[data-date-display-month]");
    const day = root.querySelector("[data-date-display-day]");
    const lunar = root.querySelector("[data-date-display-lunar]");
    const solarChain = root.querySelector("[data-date-display-solar-chain]");
    const solarTerm = root.querySelector("[data-date-display-solar-term]");
    const midRope = root.querySelector("[data-date-display-mid-rope]");
    const workdayPill = root.querySelector("[data-date-display-workday-pill]");
    const workday = root.querySelector("[data-date-display-workday]");

    if (
      !(button instanceof HTMLElement) ||
      !(weekday instanceof HTMLElement) ||
      !(month instanceof HTMLElement) ||
      !(day instanceof HTMLElement) ||
      !(lunar instanceof HTMLElement) ||
      !(solarChain instanceof HTMLElement) ||
      !(solarTerm instanceof HTMLElement) ||
      !(midRope instanceof HTMLElement) ||
      !(workdayPill instanceof HTMLElement) ||
      !(workday instanceof HTMLElement)
    ) {
      return null;
    }

    return {
      button,
      weekday,
      month,
      day,
      lunar,
      solarChain,
      solarTerm,
      midRope,
      workdayPill,
      workday,
    };
  }

  function handleDateDisplayClick() {
    const calendarModal = document.getElementById("calendar-modal");
    if (calendarModal) {
      calendarModal.classList.remove("hidden");
      document.dispatchEvent(new CustomEvent("calendar-modal-open"));
    }
  }

  function updateDateDisplays() {
    const roots = document.querySelectorAll("[data-date-display]");
    roots.forEach(node => {
      if (!(node instanceof HTMLElement)) return;
      const els = getElements(node);
      if (!els) return;

      const data = getDisplayData();

      els.button.onclick = handleDateDisplayClick;
      els.weekday.textContent = data.weekdayText;
      els.month.textContent = String(data.month);
      els.day.textContent = String(data.day);
      els.workday.textContent = data.workdayText;
      els.workday.classList.toggle("text-green-600", data.isWorkday);
      els.workday.classList.toggle("dark:text-green-400", data.isWorkday);
      els.workday.classList.toggle("text-red-600", !data.isWorkday);
      els.workday.classList.toggle("dark:text-red-400", !data.isWorkday);

      if (data.lunarText) {
        els.lunar.textContent = data.lunarText;
        els.lunar.classList.remove("hidden");
      } else {
        els.lunar.textContent = "";
        els.lunar.classList.add("hidden");
      }

      const hasSolarTerm = data.solarTerm !== "";
      els.solarTerm.textContent = data.solarTerm;
      els.solarChain.classList.toggle("hidden", !hasSolarTerm);
      els.midRope.classList.toggle("hidden", hasSolarTerm);
      els.workdayPill.classList.toggle(
        "chime-workday-pill--with-solar",
        hasSolarTerm
      );
      els.workdayPill.classList.toggle(
        "chime-workday-pill--with-rope",
        !hasSolarTerm
      );
    });
  }

  if (!globalWindow.__dateDisplayBound) {
    document.addEventListener("astro:page-load", updateDateDisplays);
    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "visible") updateDateDisplays();
    });
    window.addEventListener("pageshow", updateDateDisplays);
    document.addEventListener("DOMContentLoaded", updateDateDisplays, {
      once: true,
    });
    globalWindow.__dateDisplayIntervalId = window.setInterval(
      updateDateDisplays,
      60_000
    );
    globalWindow.__dateDisplayBound = true;
  }

  updateDateDisplays();
</script>
