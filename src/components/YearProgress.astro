---
import IconRocket from "@/assets/icons/IconRocket.svg";
---

<!-- 年度进度条（客户端计算并自动更新）：用单层 linear-gradient 画进度，避免 PC 端双元素高度错位 -->
<div class="year-progress" data-ready="0" style="--year-progress: 0%">
  <div class="year-progress-bar" style="width: 0%">
    <div class="year-progress-tooltip end">0%</div>
  </div>
  <!-- <img
    src="/progress.webp"
    alt="Progress"
    class="year-progress-image"
    style="left: 0%"
  /> -->
  <IconRocket class="year-progress-image" />
</div>

<script type="module">
  function getYearProgress() {
    const now = new Date();
    const startOfYear = new Date(now.getFullYear(), 0, 1);
    const endOfYear = new Date(now.getFullYear(), 11, 31, 23, 59, 59);

    const total = endOfYear.getTime() - startOfYear.getTime();
    const elapsed = now.getTime() - startOfYear.getTime();
    return (elapsed / total) * 100;
  }

  function easeOutCubic(t) {
    return 1 - Math.pow(1 - t, 3);
  }

  let animationId = null;
  let animating = false;
  const GLOBAL_FLAG = "__yearProgressDidInitialAnimation";

  function getElements() {
    const root = document.querySelector(".year-progress");
    if (!root) return null;
    const bar = root.querySelector(".year-progress-bar");
    const tooltip = root.querySelector(".year-progress-tooltip");
    const img = root.querySelector(".year-progress-image");
    if (!bar || !tooltip || !img) return null;
    return { root, bar, tooltip, img };
  }

  function animateTo(target, duration = 900) {
    duration = 2200;
    const els = getElements();
    if (!els) return;
    const { root, bar, tooltip, img } = els;

    const startLeft = parseFloat(bar.style.width) || 0;
    const from = Math.min(Math.max(startLeft, 0), 100);
    const to = Math.min(Math.max(target, 0), 100);
    const start = performance.now();
    animating = true;
    tooltip.classList.add("visible");
    if (animationId) cancelAnimationFrame(animationId);

    function frame(now) {
      const t = Math.min((now - start) / duration, 1);
      const eased = easeOutCubic(t);
      const current = from + (to - from) * eased;

      bar.style.width = current + "%";
      root.style.setProperty("--year-progress", current + "%");
      img.style.left = current + "%";
      const year = new Date().getFullYear();
      tooltip.textContent = `${year}年已走完 ${current.toFixed(1)}%`;

      tooltip.classList.remove("end", "center");
      tooltip.classList.add(current > 90 ? "center" : "end");

      if (t < 1) {
        animationId = requestAnimationFrame(frame);
      } else {
        animating = false;
        animationId = null;
        setTimeout(() => {
          tooltip.classList.remove("visible");
        }, 3500);
      }
    }

    animationId = requestAnimationFrame(frame);
  }

  function updateToCurrent(animate = true) {
    const progress = getYearProgress();
    if (animate) animateTo(progress);
    else {
      const els = getElements();
      if (!els) return;
      const { root, bar, tooltip, img } = els;
      bar.style.width = progress + "%";
      root.style.setProperty("--year-progress", progress + "%");
      img.style.left = progress + "%";
      const year = new Date().getFullYear();
      tooltip.textContent = `${year}年已走完 ${progress.toFixed(1)}%`;
      tooltip.classList.remove("end", "center");
      tooltip.classList.add(progress > 90 ? "center" : "end");
    }
  }

  function initYearProgress() {
    if (animating) return;
    const els = getElements();
    if (!els) return;
    const { root, bar, tooltip, img } = els;

    const hasAnimated = Boolean(window[GLOBAL_FLAG]);
    root.dataset.ready = "1";

    // 首次进入/刷新：从 0 动画到当前进度（但先隐藏，避免 0% 闪一下）
    if (!hasAnimated) {
      bar.style.width = "0%";
      root.style.setProperty("--year-progress", "0%");
      img.style.left = "0%";
      tooltip.textContent = "0%";
      window[GLOBAL_FLAG] = true;
      updateToCurrent(true);
      return;
    }

    // Astro 视图切换导航：不要回到 0%，直接同步到当前进度
    updateToCurrent(false);
  }

  // 初次加载 + Astro ClientRouter（视图切换）都会触发
  document.addEventListener("astro:page-load", initYearProgress);
  // 兜底：如果未启用 ClientRouter，也能正常初始化
  document.addEventListener("DOMContentLoaded", initYearProgress, {
    once: true,
  });

  // 每分钟检查并平滑更新（如果用户长时间打开页面）
  setInterval(() => {
    if (!animating) updateToCurrent(true);
  }, 60 * 1000);
</script>

<style>
  .year-progress {
    position: absolute;
    left: 0;
    right: 0;
    /* 4px 更抗亚像素舍入；bottom: -1px 盖住 header 的 sm:border-b，避免 PC 端出现“上细下粗/偏上” */
    bottom: -1px;
    height: 4px;
    /* 单层渐变：已走/未走同属一个 background */
    background: linear-gradient(
      to right,
      #d97706 0%,
      #d97706 var(--year-progress, 0%),
      var(--border) var(--year-progress, 0%),
      var(--border) 100%
    );
    background-origin: border-box;
    background-clip: border-box;
    overflow: visible;
    cursor: pointer;
    opacity: 0;
    transition: opacity 120ms ease;
    box-sizing: border-box;
    /* 独立层 + 不参与 flex 拉伸，减少 PC 端渲染差异 */
    transform: translateZ(0);
    flex-shrink: 0;
  }

  .year-progress[data-ready="1"] {
    opacity: 1;
  }

  .year-progress-bar {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 0%;
    background: none;
    box-sizing: border-box;
    display: block;
    pointer-events: none;
  }

  .year-progress-image {
    position: absolute;
    top: -13px;
    transform: translateX(-57%);
    height: 30px;
    object-fit: contain;
    z-index: 99;
  }

  .year-progress-tooltip {
    position: absolute;
    top: 50%;
    background-color: transparent;
    color: var(--foreground);
    padding: 0.25rem 0.5rem;
    border: none;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.2s ease,
      visibility 0.2s ease;
    pointer-events: none;
    z-index: 100;
  }

  /* 在动画或 JS 显示时使用 */
  .year-progress-tooltip.visible {
    opacity: 1;
    visibility: visible;
  }

  /* 显示在进度条末尾 */
  .year-progress-tooltip.end {
    left: 100%;
    transform: translateY(-50%);
  }

  /* 显示在进度条中间 */
  .year-progress-tooltip.center {
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .year-progress:hover .year-progress-tooltip {
    opacity: 1;
    visibility: visible;
  }
</style>
