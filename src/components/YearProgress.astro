<!-- 年度进度条（客户端计算并自动更新） -->
<div class="year-progress">
  <div class="year-progress-bar" style="width: 0%">
    <div class="year-progress-tooltip end">0%</div>
  </div>
  <img
    src="/progress.webp"
    alt="Progress"
    class="year-progress-image"
    style="left: 0%"
  />
</div>

<script type="module">
  function getYearProgress() {
    const now = new Date();
    const startOfYear = new Date(now.getFullYear(), 0, 1);
    const endOfYear = new Date(now.getFullYear(), 11, 31, 23, 59, 59);

    const total = endOfYear.getTime() - startOfYear.getTime();
    const elapsed = now.getTime() - startOfYear.getTime();
    return (elapsed / total) * 100;
  }

  function easeOutCubic(t) {
    return 1 - Math.pow(1 - t, 3);
  }

  let animationId = null;
  let animating = false;

  function animateTo(target, duration = 900) {
    duration = 2200;
    const bar = document.querySelector(".year-progress-bar");
    const tooltip = document.querySelector(".year-progress-tooltip");
    const img = document.querySelector(".year-progress-image");
    if (!bar || !tooltip || !img) return;

    const startLeft = parseFloat(bar.style.width) || 0;
    const from = Math.min(Math.max(startLeft, 0), 100);
    const to = Math.min(Math.max(target, 0), 100);
    const start = performance.now();
    animating = true;
    tooltip.classList.add("visible");
    if (animationId) cancelAnimationFrame(animationId);

    function frame(now) {
      const t = Math.min((now - start) / duration, 1);
      const eased = easeOutCubic(t);
      const current = from + (to - from) * eased;

      bar.style.width = current + "%";
      img.style.left = current + "%";
      const year = new Date().getFullYear();
      tooltip.textContent = `${year}年已走完 ${current.toFixed(1)}%`;

      tooltip.classList.remove("end", "center");
      tooltip.classList.add(current > 90 ? "center" : "end");

      if (t < 1) {
        animationId = requestAnimationFrame(frame);
      } else {
        animating = false;
        animationId = null;
        setTimeout(() => {
          tooltip.classList.remove("visible");
        }, 3500);
      }
    }

    animationId = requestAnimationFrame(frame);
  }

  function updateToCurrent(animate = true) {
    const progress = getYearProgress();
    if (animate) animateTo(progress);
    else {
      const bar = document.querySelector(".year-progress-bar");
      const tooltip = document.querySelector(".year-progress-tooltip");
      const img = document.querySelector(".year-progress-image");
      if (!bar || !tooltip || !img) return;
      bar.style.width = progress + "%";
      img.style.left = progress + "%";
      const year = new Date().getFullYear();
      tooltip.textContent = `${year}年已走完 ${progress.toFixed(1)}%`;
      tooltip.classList.remove("end", "center");
      tooltip.classList.add(progress > 90 ? "center" : "end");
    }
  }

  // 页面首次打开动画从 0 到当前进度
  document.addEventListener("DOMContentLoaded", () => {
    const bar = document.querySelector(".year-progress-bar");
    const tooltip = document.querySelector(".year-progress-tooltip");
    const img = document.querySelector(".year-progress-image");
    if (bar && tooltip && img) {
      bar.style.width = "0%";
      img.style.left = "0%";
      tooltip.textContent = `0%`;
      updateToCurrent(true);
    }
  });

  // 每分钟检查并平滑更新（如果用户长时间打开页面）
  setInterval(() => {
    if (!animating) updateToCurrent(true);
  }, 60 * 1000);
</script>

<style>
  .year-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background-color: var(--border);
    overflow: visible;
    cursor: pointer;
  }

  .year-progress-bar {
    position: relative;
    height: 100%;
    background-color: #d97706; /* 棕色 */
  }

  .year-progress-image {
    position: absolute;
    top: -20px;
    transform: translateX(-50%);
    width: 20px;
    height: 20px;
    object-fit: contain;
    z-index: 99;
  }

  .year-progress-tooltip {
    position: absolute;
    top: 50%;
    background-color: transparent;
    color: var(--foreground);
    padding: 0.25rem 0.5rem;
    border: none;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.2s ease,
      visibility 0.2s ease;
    pointer-events: none;
    z-index: 100;
  }

  /* 在动画或 JS 显示时使用 */
  .year-progress-tooltip.visible {
    opacity: 1;
    visibility: visible;
  }

  /* 显示在进度条末尾 */
  .year-progress-tooltip.end {
    left: 100%;
    transform: translateY(-50%);
  }

  /* 显示在进度条中间 */
  .year-progress-tooltip.center {
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .year-progress:hover .year-progress-tooltip {
    opacity: 1;
    visibility: visible;
  }
</style>
