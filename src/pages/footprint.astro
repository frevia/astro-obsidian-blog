---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import FootprintMap from "@/components/FootprintMap.tsx";
import { SITE } from "@/config";
import { getCollection } from "astro:content";
import postFilter from "@/utils/postFilter";
import { getPath } from "@/utils/getPath";

const blogPosts = await getCollection("blog");
const publishedPosts = blogPosts.filter(postFilter);

function parseLocationText(text: string): { lng: number; lat: number } | null {
  const [lngRaw, latRaw] = text.split(",").map(s => s.trim());
  const lng = Number(lngRaw);
  const lat = Number(latRaw);
  if (!Number.isFinite(lng) || !Number.isFinite(lat)) return null;
  if (lng < -180 || lng > 180 || lat < -90 || lat > 90) return null;
  return { lng, lat };
}

function toPlaceRecord(
  post: (typeof publishedPosts)[number]
): { name: string; lng: number; lat: number } | null {
  const { location, place, title } = post.data;
  if (!location) return null;

  const parsed = parseLocationText(location);
  if (!parsed) return null;
  return {
    name: (place || title).trim(),
    lng: parsed.lng,
    lat: parsed.lat,
  };
}

const placesFromPosts = publishedPosts
  .map(post => toPlaceRecord(post))
  .filter((loc): loc is NonNullable<ReturnType<typeof toPlaceRecord>> => Boolean(loc));

type PostLocationRecord = {
  title: string;
  url: string;
  name: string;
  lng: number;
  lat: number;
};

const postLocationRecords = publishedPosts
  .map(post => {
    const loc = toPlaceRecord(post);
    if (!loc) return null;
    return {
      title: post.data.title,
      url: getPath(post.id, post.filePath),
      name: loc.name,
      lng: loc.lng,
      lat: loc.lat,
    } satisfies PostLocationRecord;
  })
  .filter((item): item is PostLocationRecord => Boolean(item));

const uniquePlaces = Array.from(
  new Map(
    placesFromPosts.map(loc => [`${loc.name}:${loc.lng},${loc.lat}`, loc] as const)
  ).values()
);

const places = uniquePlaces;
---

<Layout title={`足迹 | ${SITE.title}`}>
  <Header />
  <Main pageTitle="开发中……" pageDesc="「旅行是最热闹的孤独，是一场向着内心的出走； 旅行是一部电影，笑中带泪; 旅行是一首没有伴奏的歌，五音不全，旁人全听它不懂，只剩下垂垂暮年的你，独自蜷缩在摇椅上的毯子下面，露出不易察觉的最后一丝微笑。」" pageDescClass="text-justify">
    <FootprintMap client:load places={places} records={postLocationRecords} />
  </Main>
  <Footer />
</Layout>
