---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import FootprintMap from "@/components/FootprintMap.tsx";
import { SITE } from "@/config";
import { getCollection } from "astro:content";
import postFilter from "@/utils/postFilter";
import { getPath } from "@/utils/getPath";

const blogPosts = await getCollection("blog");
const publishedPosts = blogPosts.filter(postFilter);

type PlaceRecord = {
  name: string;
  lng: number;
  lat: number;
};

function parseLocationText(text: string): PlaceRecord | null {
  const parts = text.split(",").map(s => s.trim());
  if (parts.length < 3) return null;

  const name = parts.slice(0, -2).join(",").trim();
  const lngRaw = parts.at(-2);
  const latRaw = parts.at(-1);
  if (!name || !lngRaw || !latRaw) return null;

  const lng = Number(lngRaw);
  const lat = Number(latRaw);
  if (!Number.isFinite(lng) || !Number.isFinite(lat)) return null;
  if (lng < -180 || lng > 180 || lat < -90 || lat > 90) return null;
  return { name, lng, lat };
}

function toPlaceRecords(post: (typeof publishedPosts)[number]): PlaceRecord[] {
  const { locations } = post.data;
  if (!locations?.length) return [];
  return locations.filter(Boolean).map(parseLocationText).filter(Boolean) as PlaceRecord[];
}

const placesFromPosts = publishedPosts
  .flatMap(post => toPlaceRecords(post))
  .filter((loc): loc is PlaceRecord => Boolean(loc));

type PostLocationRecord = {
  title: string;
  url: string;
  name: string;
  lng: number;
  lat: number;
};

const postLocationRecords = publishedPosts
  .flatMap(post =>
    toPlaceRecords(post).map(
      loc =>
        ({
          title: post.data.title,
          url: getPath(post.id, post.filePath),
          name: loc.name,
          lng: loc.lng,
          lat: loc.lat,
        }) satisfies PostLocationRecord
    )
  );

const uniquePlaces = Array.from(
  new Map(
    placesFromPosts.map(loc => [`${loc.name}:${loc.lng},${loc.lat}`, loc] as const)
  ).values()
);

const places = Array.from(
  new Map(
    uniquePlaces.map(loc => [`${loc.name}:${loc.lng},${loc.lat}`, loc] as const)
  ).values()
);
---

<Layout title={`足迹 | ${SITE.title}`}>
  <Header />
  <Main pageTitle="开发中……" pageDesc="「旅行是最热闹的孤独，是一场向着内心的出走； 旅行是一部电影，笑中带泪; 旅行是一首没有伴奏的歌，五音不全，旁人全听它不懂，只剩下垂垂暮年的你，独自蜷缩在摇椅上的毯子下面，露出不易察觉的最后一丝微笑。」" pageDescClass="text-justify">
    <FootprintMap client:load places={places} records={postLocationRecords} />
  </Main>
  <Footer />
</Layout>
