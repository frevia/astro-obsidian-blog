---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import getPostsByGroupCondition from "@/utils/getPostsByGroupCondition";
import postFilter from "@/utils/postFilter";
import { SITE } from "@/config";
import { getYearMonthInTimeZone } from "@/utils/calendarDate";

// Redirect to 404 page if `showArchives` config is false
if (!SITE.showArchives) {
  return Astro.redirect("/404");
}

const posts = await getCollection("blog", postFilter);

const months = [
  "一月",
  "二月",
  "三月",
  "四月",
  "五月",
  "六月",
  "七月",
  "八月",
  "九月",
  "十月",
  "十一月",
  "十二月",
];
---

<Layout title={`收集箱 | ${SITE.title}`}>
  <Header />
  <Main pageTitle="收集箱" pageDesc="按时间顺序整理的所有文章归档">
    <!-- 页面描述区域 -->
    <div
      class="mb-8 rounded-xl border-l-4 border-accent/60 bg-accent/5 px-4 py-4 text-sm text-foreground/80"
    >
      <div class="flex items-start gap-3">
        <span class="mt-0.5 text-lg text-accent/80">📦</span>
        <div class="flex-1">
          <p class="mb-2 text-base font-semibold text-foreground/90">
            文章归档
          </p>
          <p class="mb-2">
            这里按时间顺序整理了所有已发布的文章，方便您按年月浏览。
          </p>
          <div class="flex flex-wrap gap-4 text-xs text-foreground/60">
            <span class="flex items-center gap-1.5">
              <span class="h-2 w-2 rounded-full bg-accent/60"></span>
              按年份和月份分组
            </span>
            <span class="flex items-center gap-1.5">
              <span class="h-2 w-2 rounded-full bg-accent/40"></span>
              支持快速跳转浏览
            </span>
            <span class="flex items-center gap-1.5">
              <span class="h-2 w-2 rounded-full bg-accent/20"></span>
              完整的文章时间线
            </span>
          </div>
        </div>
      </div>
    </div>
    {
      Object.entries(
        getPostsByGroupCondition(
          posts,
          post => getYearMonthInTimeZone(post.data.published).year
        )
      )
        .sort(([yearA], [yearB]) => Number(yearB) - Number(yearA))
        .map(([year, yearGroup]) => (
          <div class="mb-8">
            <div class="mb-6 flex items-center justify-between border-b border-border/30 pb-3">
              <div class="flex items-baseline gap-3">
                <span class="text-2xl font-bold text-foreground/90">
                  {year}
                </span>
                <sup class="rounded-full bg-accent/10 px-2.5 py-1 text-sm font-medium text-accent">
                  {yearGroup.length} 篇
                </sup>
              </div>
              <div class="text-xs text-foreground/40">按发布时间排序</div>
            </div>
            {Object.entries(
              getPostsByGroupCondition(
                yearGroup,
                post =>
                  getYearMonthInTimeZone(post.data.published).monthIndex + 1
              )
            )
              .sort(([monthA], [monthB]) => Number(monthB) - Number(monthA))
              .map(([month, monthGroup]) => (
                <div
                  class="flex flex-col gap-4 sm:flex-row sm:items-start"
                  data-month-group
                >
                  <div class="mt-4 mb-1 min-w-32 sm:mt-6 sm:mb-0">
                    <span class="border-l-3 border-accent pl-3 text-base font-semibold tracking-wide text-foreground/80 sm:border-l-0 sm:pl-0">
                      {months[Number(month) - 1]}
                    </span>
                  </div>
                  <ul>
                    {monthGroup
                      .sort(
                        (a, b) =>
                          Math.floor(
                            new Date(b.data.published).getTime() / 1000
                          ) -
                          Math.floor(
                            new Date(a.data.published).getTime() / 1000
                          )
                      )
                      .map(data => (
                        <Card {...data} />
                      ))}
                  </ul>
                </div>
              ))}
          </div>
        ))
    }
  </Main>
  <Footer />
</Layout>

<style>
  /* 移动端优化 */
  @media (max-width: 640px) {
    [data-month-group] {
      position: relative;
      padding-left: 1.25rem;
      margin-left: 0.75rem;
    }

    [data-month-group]::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0.25rem;
      bottom: 0.25rem;
      width: 4px;
      background: linear-gradient(
        to bottom,
        var(--accent),
        color-mix(in oklab, var(--accent) 70%, transparent)
      );
      border-radius: 4px;
    }

    [data-month-group] > div:first-child {
      margin-bottom: 0.5rem;
    }

    [data-month-group] > div:first-child span {
      border-left: none !important;
      padding-left: 0 !important;
      font-weight: 600;
      letter-spacing: 0.5px;
    }
  }
</style>
