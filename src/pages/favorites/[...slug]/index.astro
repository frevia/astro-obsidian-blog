---
import "tocbot/dist/tocbot.css";
import { render, type CollectionEntry, getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import Datetime from "@/components/Datetime.astro";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";
import { slugifyStr } from "@/utils/slugify";

export interface Props {
  post: CollectionEntry<"clip">;
}

export async function getStaticPaths() {
  const posts = await getCollection("clip");
  const resolveFavoriteSlug = (post: CollectionEntry<"clip">) => {
    const trimmedSlug = post.data.slug?.trim();
    if (trimmedSlug) return trimmedSlug;
    return slugifyStr(post.data.title);
  };

  return posts.map(post => ({
    params: { slug: resolveFavoriteSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const { title, description, published, created, timezone, source, tags } =
  post.data;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  description,
  published,
  scrollSmooth: true,
};

const favoritePosts = (await getCollection("clip")).sort(
  (a, b) =>
    Math.floor(new Date(b.data.published).getTime() / 1000) -
    Math.floor(new Date(a.data.published).getTime() / 1000)
);

const allFavorites = favoritePosts.map(({ data: { title, slug }, id }) => ({
  id,
  title,
  slug,
}));

const resolveFavoriteSlug = (slug: string | undefined, title: string) => {
  const trimmedSlug = slug?.trim();
  if (trimmedSlug) return trimmedSlug;
  return slugifyStr(title);
};

const getFavoritePath = (slug: string | undefined, title: string) => {
  return `/favorites/${resolveFavoriteSlug(slug, title)}`;
};

const currentPostIndex = allFavorites.findIndex(item => item.id === post.id);
const prevPost =
  currentPostIndex > 0 ? allFavorites[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex >= 0 && currentPostIndex < allFavorites.length - 1
    ? allFavorites[currentPostIndex + 1]
    : null;
---

<Layout {...layoutProps}>
  <Header />
  <BackButton />
  <main
    id="main-content"
    class="mx-auto mt-4 w-full max-w-app px-4 pb-12"
    data-pagefind-body
    data-pagefind-weight="5"
  >
    <h1
      transition:name={slugifyStr(title)}
      class="inline-block text-2xl font-bold text-accent sm:text-3xl"
      data-pagefind-meta="title"
    >
      {title}
    </h1>
    {
      tags.length > 0 && (
        <div class="sr-only" data-pagefind-meta="tag">
          {tags.join(", ")}
        </div>
      )
    }
    <div class="my-2">
      <Datetime
        {published}
        created={created}
        {timezone}
        size="lg"
        showCreated={true}
        detailPage={true}
      />
    </div>

    <!-- 转载说明放在文章内容之前 -->
    <div
      class="mb-6 rounded-xl border-l-4 border-accent/60 bg-accent/5 px-4 py-3 text-sm text-foreground/80"
    >
      <div class="flex items-start gap-2">
        <span class="mt-0.5 text-accent/80">📚</span>
        <div class="flex-1">
          <p class="font-medium text-foreground/90">转载说明</p>
          <p class="mt-1">本文转载或收集自互联网，仅作学习与整理使用。</p>
          {
            source ? (
              <p class="mt-2">
                原文链接：
                <a
                  href={source}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-medium text-accent underline-offset-4 hover:underline"
                >
                  {source}
                </a>
              </p>
            ) : (
              <p class="mt-2 text-foreground/70">
                若内容涉及侵权，请联系删除。
              </p>
            )
          }
        </div>
      </div>
    </div>

    <article
      id="article"
      class="js-toc-content app-prose relative mx-auto max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
    >
      <Content />
    </article>
    <BackToTopButton />
    <aside id="sidebar" class="sidebar toc-empty hidden lg:block">
      <div class="toc-title mb-2 text-sm font-medium">页面导航</div>
      <div id="toc-container" class="js-toc"></div>
    </aside>

    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={getFavoritePath(prevPost.slug, prevPost.title)}
            class="flex w-full gap-1 hover:opacity-75"
          >
            <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
            <div>
              <span>上一篇</span>
              <div class="text-sm text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getFavoritePath(nextPost.slug, nextPost.title)}
            class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
          >
            <div>
              <span>下一篇</span>
              <div class="text-sm text-accent/85">{nextPost.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import tocbot from "tocbot";

  document.addEventListener("astro:page-load", () => {
    const header = document.getElementById("site-header");
    const tocOffset =
      header instanceof HTMLElement ? header.offsetHeight + 8 : 0;
    const sidebar = document.getElementById("sidebar");
    const tocContainer = document.getElementById("toc-container");

    if (!tocContainer) return;

    tocbot.destroy();
    tocbot.init({
      tocSelector: ".js-toc",
      contentSelector: ".js-toc-content",
      headingSelector: "h2, h3, h4",
      ignoreSelector: "h1",
      hasInnerContainers: true,
      headingsOffset: tocOffset,
      scrollSmoothDuration: 300,
      scrollSmoothOffset: -tocOffset,
    });

    const hasTocItem =
      tocContainer.querySelector(".toc-list-item, .toc-link") !== null;
    if (sidebar) {
      sidebar.classList.toggle("toc-empty", !hasTocItem);
    }
  });
</script>
