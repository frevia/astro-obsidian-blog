---
import "tocbot/dist/tocbot.css";
import { render, type CollectionEntry, getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import Datetime from "@/components/Datetime.astro";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";
import { slugifyStr } from "@/utils/slugify";
import getPostsByGroupCondition from "@/utils/getPostsByGroupCondition";
import { getYearMonthInTimeZone } from "@/utils/calendarDate";

export interface Props {
  post: CollectionEntry<"clip">;
}

export async function getStaticPaths() {
  const posts = await getCollection("clip");
  const resolveFavoriteSlug = (post: CollectionEntry<"clip">) => {
    const trimmedSlug = post.data.slug?.trim();
    if (trimmedSlug) return trimmedSlug;
    return slugifyStr(post.data.title);
  };

  return posts.map(post => ({
    params: { slug: resolveFavoriteSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const {
  title,
  description,
  published,
  created,
  timezone,
  source,
  summary,
  tags,
} = post.data;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  description,
  published,
  scrollSmooth: true,
};

const allClips = await getCollection("clip");
const getGroupingDate = (item: CollectionEntry<"clip">) =>
  item.data.created || item.data.published;

const favoritePosts = Object.entries(
  getPostsByGroupCondition(
    allClips,
    item => getYearMonthInTimeZone(getGroupingDate(item)).year
  )
)
  .sort(([yearA], [yearB]) => Number(yearB) - Number(yearA))
  .flatMap(([, yearGroup]) =>
    Object.entries(
      getPostsByGroupCondition(
        yearGroup,
        item => getYearMonthInTimeZone(getGroupingDate(item)).monthIndex + 1
      )
    )
      .sort(([monthA], [monthB]) => Number(monthB) - Number(monthA))
      .flatMap(([, monthGroup]) =>
        [...monthGroup].sort(
          (a, b) =>
            Math.floor(
              new Date(b.data.created ?? b.data.published).getTime() / 1000
            ) -
            Math.floor(
              new Date(a.data.created ?? a.data.published).getTime() / 1000
            )
        )
      )
  );

const allFavorites = favoritePosts.map(({ data: { title, slug }, id }) => ({
  id,
  title,
  slug,
}));

const resolveFavoriteSlug = (slug: string | undefined, title: string) => {
  const trimmedSlug = slug?.trim();
  if (trimmedSlug) return trimmedSlug;
  return slugifyStr(title);
};

const getFavoritePath = (slug: string | undefined, title: string) => {
  return `/favorites/${resolveFavoriteSlug(slug, title)}`;
};

const currentPostIndex = allFavorites.findIndex(item => item.id === post.id);
const prevPost =
  currentPostIndex > 0 ? allFavorites[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex >= 0 && currentPostIndex < allFavorites.length - 1
    ? allFavorites[currentPostIndex + 1]
    : null;
---

<Layout {...layoutProps}>
  <Header />
  <BackButton />
  <main
    id="main-content"
    class="mx-auto mt-4 w-full max-w-app px-4 pb-12"
    data-pagefind-body
    data-pagefind-weight="5"
  >
    <h1
      transition:name={slugifyStr(title)}
      class="inline-block text-2xl font-bold text-accent sm:text-3xl"
      data-pagefind-meta="title"
    >
      {title}
    </h1>
    {
      tags.length > 0 && (
        <div class="sr-only" data-pagefind-meta="tag">
          {tags.join(", ")}
        </div>
      )
    }
    <div class="my-2">
      <Datetime
        {published}
        created={created}
        {timezone}
        size="lg"
        showCreated={true}
        detailPage={true}
      />
    </div>

    <!-- 转载说明放在文章内容之前 -->
    <div
      class="mb-6 rounded-xl border-l-4 border-accent/60 bg-accent/5 px-4 py-3 text-sm text-foreground/80"
    >
      <div class="flex items-start gap-2">
        <span class="mt-0.5 text-accent/80">📚</span>
        <div class="min-w-0 flex-1">
          <p class="font-medium text-foreground/90">转载说明</p>
          <p class="mt-1">
            本文转载或收集自互联网，仅作学习与整理使用。若内容涉及侵权，请联系删除。
          </p>
          {
            source ? (
              <p class="mt-2 flex min-w-0 items-center gap-1">
                <span class="shrink-0">原文链接：</span>
                <a
                  href={source}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block min-w-0 flex-1 truncate font-medium text-accent underline-offset-4 hover:underline"
                  title={source}
                >
                  {source}
                </a>
              </p>
            ) : null
          }
        </div>
      </div>
    </div>

    {
      summary && (
        <div class="mt-6 mb-8 rounded-lg border border-purple-500/10 bg-gradient-to-br from-purple-500/20 via-purple-500/5 to-blue-500/10 p-4 font-sans shadow-[inset_0_2px_6px_rgba(0,0,0,0.05)] selection:bg-purple-800/40 dark:selection:bg-purple-200/50">
          <div class="mb-3 flex items-center gap-2">
            <svg class="h-5 w-5" fill="url(#starGradient)" viewBox="0 0 24 24">
              <defs>
                <linearGradient
                  id="starGradient"
                  x1="0%"
                  y1="0%"
                  x2="100%"
                  y2="100%"
                >
                  <stop offset="0%" style="stop-color:#e0abff" />
                  <stop offset="100%" style="stop-color:#7a43d8" />
                </linearGradient>
              </defs>
              <path d="M12 2L9.1 9.1 2 12l7.1 2.9L12 22l2.9-7.1L22 12l-7.1-2.9z" />
              <path
                fill="url(#starGradient)"
                transform="translate(16, 0) scale(0.4)"
                d="M12 2L9.1 9.1 2 12l7.1 2.9L12 22l2.9-7.1L22 12l-7.1-2.9z"
              />
            </svg>
            <h3 class="bg-gradient-to-r from-purple-400 to-purple-600 bg-clip-text text-lg font-bold text-transparent">
              AI 总结
            </h3>
          </div>

          <p class="text-sm leading-relaxed text-foreground/80">{summary}</p>
        </div>
      )
    }

    <article
      id="article"
      class="js-toc-content app-prose relative mx-auto max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
    >
      <Content />
    </article>
    <BackToTopButton />
    <aside id="sidebar" class="sidebar toc-empty hidden lg:block">
      <div class="toc-title mb-2 text-sm font-medium">页面导航</div>
      <div id="toc-container" class="js-toc"></div>
    </aside>

    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={getFavoritePath(prevPost.slug, prevPost.title)}
            class="flex w-full gap-1 hover:opacity-75"
          >
            <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
            <div>
              <span>上一篇</span>
              <div class="text-sm text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getFavoritePath(nextPost.slug, nextPost.title)}
            class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
          >
            <div>
              <span>下一篇</span>
              <div class="text-sm text-accent/85">{nextPost.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import tocbot from "tocbot";

  document.addEventListener("astro:page-load", () => {
    const header = document.getElementById("site-header");
    const tocOffset =
      header instanceof HTMLElement ? header.offsetHeight + 8 : 0;
    const sidebar = document.getElementById("sidebar");
    const tocContainer = document.getElementById("toc-container");

    if (!tocContainer) return;

    tocbot.destroy();
    tocbot.init({
      tocSelector: ".js-toc",
      contentSelector: ".js-toc-content",
      headingSelector: "h2, h3, h4",
      ignoreSelector: "h1",
      hasInnerContainers: true,
      headingsOffset: tocOffset,
      scrollSmoothDuration: 300,
      scrollSmoothOffset: -tocOffset,
    });

    const hasTocItem =
      tocContainer.querySelector(".toc-list-item, .toc-link") !== null;
    if (sidebar) {
      sidebar.classList.toggle("toc-empty", !hasTocItem);
    }
  });
</script>
