---
import { getCollection, type CollectionEntry } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Datetime from "@/components/Datetime.astro";
import getPostsByGroupCondition from "@/utils/getPostsByGroupCondition";
import { SITE } from "@/config";
import { getYearMonthInTimeZone } from "@/utils/calendarDate";
import { slugifyStr } from "@/utils/slugify";

const clips = await getCollection("clip");
const allTags = Array.from(
  new Set(
    clips.flatMap(clip => clip.data.tags.map(tag => tag.trim()).filter(Boolean))
  )
).sort((a, b) => a.localeCompare(b, "zh-CN"));

const months = [
  "一月",
  "二月",
  "三月",
  "四月",
  "五月",
  "六月",
  "七月",
  "八月",
  "九月",
  "十月",
  "十一月",
  "十二月",
];

const resolveFavoriteSlug = (slug: string | undefined, title: string) => {
  const trimmedSlug = slug?.trim();
  if (trimmedSlug) return trimmedSlug;
  return slugifyStr(title);
};

const getFavoritePath = (
  slug: string | undefined,
  title: string,
  includeBase = true
) => {
  const basePath = includeBase ? "/favorites" : "";
  const favoriteSlug = resolveFavoriteSlug(slug, title);
  return [basePath, favoriteSlug].join("/");
};

// 辅助函数：获取用于分组的日期（优先使用 created，不存在时使用 published）
const getGroupingDate = (post: CollectionEntry<"clip">) => {
  return post.data.created || post.data.published;
};
---

<Layout title={`收藏 | ${SITE.title}`}>
  <Header />
  <Main
    pageTitle="收藏"
    pageDesc="文章转载或收集自互联网，仅作学习与整理使用。"
  >
    <!-- 转载说明卡片 -->
    <!-- <div
      class="mb-6 rounded-xl border-l-4 border-accent/60 bg-accent/5 px-4 py-3 text-sm text-foreground/80"
    >
      <div class="flex items-start gap-2">
        <span class="mt-0.5 text-accent/80">📚</span>
        <div class="flex-1">
          <p class="font-medium text-foreground/90">转载说明</p>
          <p class="mt-1">文章转载或收集自互联网，仅作学习与整理使用。</p>
          <p class="mt-2 text-foreground/70">若内容涉及侵权，请联系删除。</p>
        </div>
      </div>
    </div> -->
    {
      allTags.length > 0 && (
        <div class="mb-6" id="favorites-tag-filter" data-pagefind-ignore>
          <p class="mb-2 text-sm font-medium">标签筛选</p>
          <div class="flex flex-wrap gap-1.5">
            <button
              type="button"
              data-filter-tag=""
              class="favorite-filter-btn is-active rounded-full border border-border px-3.5 py-1.5 text-sm font-medium transition-all hover:border-accent/50 hover:text-accent"
            >
              全部
            </button>
            {allTags.map(tag => (
              <button
                type="button"
                data-filter-tag={tag}
                class="favorite-filter-btn rounded-full border border-border/60 px-3 py-1.5 text-sm font-medium transition-all hover:border-accent/30 hover:text-accent"
              >
                #{tag}
              </button>
            ))}
          </div>
        </div>
      )
    }
    <div data-pagefind-body data-pagefind-weight="4">
      {
        Object.entries(
          getPostsByGroupCondition(
            clips,
            post => getYearMonthInTimeZone(getGroupingDate(post)).year
          )
        )
          .sort(([yearA], [yearB]) => Number(yearB) - Number(yearA))
          .map(([year, yearGroup]) => (
            <div data-year-group class="mb-8">
              <div class="mb-6 flex items-center justify-between border-b border-border/30 pb-3">
                <div class="flex items-baseline gap-3">
                  <span class="text-2xl font-bold text-foreground/90">
                    {year}
                  </span>
                  <sup class="rounded-full bg-accent/10 px-2.5 py-1 text-sm font-medium text-accent">
                    {yearGroup.length} 篇
                  </sup>
                </div>
                <div class="text-xs text-foreground/40">按收录时间排序</div>
              </div>
              {Object.entries(
                getPostsByGroupCondition(
                  yearGroup,
                  post =>
                    getYearMonthInTimeZone(getGroupingDate(post)).monthIndex + 1
                )
              )
                .sort(([monthA], [monthB]) => Number(monthB) - Number(monthA))
                .map(([month, monthGroup]) => (
                  <div class="flex flex-col gap-4 sm:flex-row" data-month-group>
                    <div class="mt-4 mb-1 min-w-32 sm:mt-6 sm:mb-0">
                      <span class="border-l-3 border-accent pl-3 text-base font-semibold tracking-wide text-foreground/80 sm:border-l-0 sm:pl-0">
                        {months[Number(month) - 1]}
                      </span>
                    </div>
                    <ul class="sm:flex-1">
                      {monthGroup
                        .sort(
                          (a, b) =>
                            Math.floor(
                              new Date(
                                b.data.created ?? b.data.published
                              ).getTime() / 1000
                            ) -
                            Math.floor(
                              new Date(
                                a.data.created ?? a.data.published
                              ).getTime() / 1000
                            )
                        )
                        .map(post => (
                          <li
                            class="mb-3 border-b border-border/20 pb-3 last:mb-0 last:border-b-0"
                            data-favorite-item
                            data-tags={post.data.tags.join("||")}
                          >
                            <a
                              href={getFavoritePath(
                                post.data.slug,
                                post.data.title
                              )}
                              class="group block"
                            >
                              <h3 class="mb-1.5 text-lg leading-relaxed font-medium text-foreground/90 transition-colors group-hover:text-accent">
                                {post.data.title}
                              </h3>
                              <div class="flex flex-wrap items-center gap-1.5 text-sm text-foreground/70">
                                <div class="flex items-center gap-1.5">
                                  <Datetime
                                    published={post.data.published}
                                    created={post.data.created}
                                    timezone={post.data.timezone}
                                    showCreated={true}
                                  />
                                </div>

                                {post.data.tags.length > 0 && (
                                  <>
                                    <span class="mx-0.5 hidden text-foreground/40 sm:inline">
                                      ·
                                    </span>
                                    <span class="flex items-center gap-1">
                                      {post.data.tags.slice(0, 2).map(tag => (
                                        <span class="rounded-full bg-muted/40 px-2 py-0.5 text-xs font-medium tracking-wide">
                                          #{tag}
                                        </span>
                                      ))}
                                      {post.data.tags.length > 2 && (
                                        <span class="text-xs text-foreground/50">
                                          +{post.data.tags.length - 2}
                                        </span>
                                      )}
                                    </span>
                                  </>
                                )}
                              </div>

                              {post.data.source && (
                                <div class="mt-1 text-sm leading-tight text-foreground/50">
                                  <span class="inline-flex max-w-full items-center">
                                    来源:{" "}
                                    <span
                                      class="truncate font-medium"
                                      title={post.data.source}
                                      style="max-width: 550px;"
                                    >
                                      {post.data.source}
                                    </span>
                                  </span>
                                </div>
                              )}
                            </a>
                          </li>
                        ))}
                    </ul>
                  </div>
                ))}
            </div>
          ))
      }
      <div
        id="favorites-empty"
        class="hidden py-16 text-center"
        data-pagefind-ignore
      >
        <div class="mb-4 text-5xl text-foreground/40">📚</div>
        <p class="text-base font-medium text-foreground/70">
          当前标签下暂无收藏内容
        </p>
        <p class="mt-2 text-sm text-foreground/50">
          试试选择其他标签或查看全部内容
        </p>
        <button
          onclick="applyFilter('')"
          class="mt-4 rounded-full bg-accent/10 px-4 py-2 text-sm font-medium text-accent transition-colors hover:bg-accent/20"
        >
          查看全部内容
        </button>
      </div>
    </div>
  </Main>
  <Footer />
</Layout>

<style>
  .favorite-filter-btn {
    transition: all 0.2s ease;
  }

  .favorite-filter-btn.is-active {
    color: var(--accent);
    border-color: color-mix(in oklab, var(--accent) 45%, var(--border));
    background: color-mix(in oklab, var(--accent) 12%, transparent);
  }

  [data-favorite-item] {
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }

  [data-favorite-item].filtering {
    opacity: 0.5;
    transform: translateX(-10px);
  }

  /* 优化列表项交互效果 */
  [data-favorite-item] {
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  [data-favorite-item] a {
    transition: all 0.2s ease;
  }

  [data-favorite-item]:hover {
    background: color-mix(in oklab, var(--accent) 3%, transparent);
    border-radius: 0.5rem;
    margin: 0 -0.75rem;
    padding: 0.5rem 0.75rem;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  /* 移动端优化 */
  @media (max-width: 640px) {
    [data-month-group] {
      position: relative;
      padding-left: 1.25rem;
      margin-left: 0.75rem;
    }

    [data-month-group]::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0.25rem;
      bottom: 0.25rem;
      width: 4px;
      background: linear-gradient(
        to bottom,
        var(--accent),
        color-mix(in oklab, var(--accent) 70%, transparent)
      );
      border-radius: 4px;
    }

    [data-month-group] > div:first-child {
      margin-bottom: 0.5rem;
    }

    [data-month-group] > div:first-child span {
      border-left: none !important;
      padding-left: 0 !important;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .favorite-filter-btn {
      font-size: 0.875rem;
      padding: 0.5rem 0.75rem;
    }

    /* 移动端列表项优化 */
    [data-favorite-item] {
      margin-left: -0.25rem;
      margin-right: -0.25rem;
      padding-left: 0.25rem;
      padding-right: 0.25rem;
    }

    [data-favorite-item]:hover {
      margin: 0 -0.5rem;
      padding: 0.5rem 0.5rem;
      transform: translateY(-1px);
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
    }
  }
</style>

<script is:inline>
  const initFavoriteTagFilter = () => {
    const filterRoot = document.getElementById("favorites-tag-filter");
    if (!filterRoot) return;

    const buttons = Array.from(
      filterRoot.querySelectorAll("[data-filter-tag]")
    );
    const items = Array.from(document.querySelectorAll("[data-favorite-item]"));
    const monthGroups = Array.from(
      document.querySelectorAll("[data-month-group]")
    );
    const yearGroups = Array.from(
      document.querySelectorAll("[data-year-group]")
    );
    const emptyHint = document.getElementById("favorites-empty");

    const applyFilter = activeTag => {
      buttons.forEach(btn => {
        btn.classList.toggle(
          "is-active",
          (btn.dataset.filterTag ?? "") === activeTag
        );
      });

      items.forEach(item => {
        const tagsRaw = item.dataset.tags ?? "";
        const tags = tagsRaw ? tagsRaw.split("||").filter(Boolean) : [];
        const visible = !activeTag || tags.includes(activeTag);
        item.classList.toggle("hidden", !visible);
      });

      monthGroups.forEach(group => {
        const visibleCount = group.querySelectorAll(
          "[data-favorite-item]:not(.hidden)"
        ).length;
        group.classList.toggle("hidden", visibleCount === 0);
      });

      yearGroups.forEach(group => {
        const visibleCount = group.querySelectorAll(
          "[data-month-group]:not(.hidden)"
        ).length;
        group.classList.toggle("hidden", visibleCount === 0);
      });

      const anyVisible = items.some(item => !item.classList.contains("hidden"));
      if (emptyHint) emptyHint.classList.toggle("hidden", anyVisible);
    };

    buttons.forEach(btn => {
      btn.addEventListener("click", () => {
        applyFilter(btn.dataset.filterTag ?? "");
      });
    });

    applyFilter("");
  };

  initFavoriteTagFilter();
  document.addEventListener("astro:page-load", initFavoriteTagFilter);
</script>
