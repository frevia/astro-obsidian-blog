{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "public/pagefind", "src/data"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/data/*": ["./public/data/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
